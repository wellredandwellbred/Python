# Challenge #2 Factorials
# Write a program that calculates the factorial of a given integer.

# program name
print("Calculating Factorials")

# input varaible
userInput = int(input())

# set index
result = 1

# calculate factorial
if userInput <= 1:
    print(result)
else:
    for i in range(1,userInput + 1):
        result *= i
    print(result)

