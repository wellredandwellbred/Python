# Challenge #1 Bill Split Calculator

# program name
print("Bill Split Calculator")
 
# input variables
billAmount = float(input())
tipPercentage = float(input())
 
# bill total calculations
tipAmount = (tipPercentage / 100) * billAmount
totalBill = billAmount + tipAmount
 
print(f"Total (including tip): ${totalBill}")
 
# split bill
guests = int(input())
eachPay = totalBill / guests
 
print(f"Each person pays: ${eachPay}")




# Challenge #2 Factorials

# program name
print("Calculating Factorials")

# input varaible
userInput = int(input())

# set index
result = 1

# calculate factorial
if userInput <= 1:
    print(result)
else:
    for i in range(1,userInput + 1):
        result *= i
    print(result)

